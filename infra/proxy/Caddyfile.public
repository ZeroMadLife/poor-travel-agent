{
	admin off
	auto_https disable_redirects
	http_port 8081
	https_port 8443
}

# Direct public fallback while the domain is pending ICP filing.
http://121.40.185.188 {
	route {
		import /etc/caddy/public-agent
		import /etc/caddy/public-static
	}
}

http://:8081 {
	route {
		@health path /healthz
		respond @health "<title>Sage health</title>" 200
		redir https://{host}{uri} permanent
	}
}

sagecompanion.top, www.sagecompanion.top {
	route {
		import /etc/caddy/public-agent
		import /etc/caddy/public-static
	}
}
